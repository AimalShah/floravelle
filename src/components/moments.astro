---
import "../styles/global.css"
import {Image} from "astro:assets"
import bannerImg from "../assets/banner.png"
---

<section class="mt-12 md:mt-20 bg-[#E8E4DE]">
  <div class="container mx-auto py-10 md:py-18 gap-8 md:gap-18 flex flex-col-reverse md:flex-row px-4 md:px-0">
    <div class="font-primary md:px-18 flex-1 space-y-6 md:space-y-8 flex flex-col justify-center items-start">
      <h1 class="text-4xl md:text-6xl">Aroma Moments</h1> 
      <p class="text-lg md:text-xl w-full md:w-[80%]">Experinece our exclusive collection of scents, crafted to enrich your daily elegence.</p>
      <button class="text-lg md:text-2xl font-semibold border-[#7A5633] text-[#8A5633] hover:bg-[#7A5633] hover:text-white rounded-full px-6 py-3 md:p-4 border cursor-pointer">
        Explore Now 
      </button>
    </div>
    <div class="flex-1 bg-red-200 shadow"> 
      <Image
      src={bannerImg}
      alt="banner"
      class="w-full h-full object-cover"
      /> 
    </div>
  </div>
</section>



