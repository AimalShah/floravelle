---
import "../styles/global.css"
import {Image} from "astro:assets"
import bannerImg from "../assets/banner.png"
---

<section class="mt-20 bg-[#E8E4DE]">
  <div class="container mx-auto py-18 gap-18 flex">
    <div class="font-primary  px-18  flex-1 space-y-8 flex flex-col justify-center items-start">
      <h1 class="text-6xl">Aroma Moments</h1> 
      <p class="text-xl  w-[80%]">Experinece our exclusive collection of scents, crafted to enrich your daily elegence.</p>
      <button class="text-2xl font-semibold border-[#7A5633] text-[#8A5633] hover:bg-[#7A5633] hover:text-white rounded-full p-4 border  cursor-pointer ">
        Explore Now 
      </button>
    </div>
    <div class="flex-1 bg-red-200 shadow"> 
      <Image
      src={bannerImg}
      alt="banner"
      class="w-full h-full object-cover"
      /> 
    </div>
  </div>
</section>



