---
import "../styles/global.css"
---


<footer class="bg-[#E8E4DE] py-8">
  <div class="container mx-auto font-primary w-full relative h-auto px-4 md:px-0">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12 md:mb-24">
      <nav>
        <h3 class="text-xl font-bold mb-4">Explore</h3>
        <ul class="flex flex-col text-lg font-thin text-black/70 space-y-2">
          <a class="cursor-pointer hover:text-black transition-colors" href="/collection">Collection</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="/#products">Signature Scents</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="/collection">Gifts & Sets</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="/collection">New Arrivals</a> 
        </ul>
      </nav>
      <nav>
        <h3 class="text-xl font-bold mb-4">Company</h3>
        <ul class="flex flex-col text-lg font-thin text-black/70 space-y-2">
          <a class="cursor-pointer hover:text-black transition-colors" href="/about">About Us</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Our Philosophy</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Sustainability</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Careers</a> 
        </ul>
      </nav>
      <nav>
        <h3 class="text-xl font-bold mb-4">Support</h3>
        <ul class="flex flex-col text-lg font-thin text-black/70 space-y-2">
          <a class="cursor-pointer hover:text-black transition-colors" href="/contact">Contact Us</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Shipping & Returns</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">FAQ</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Track Order</a> 
        </ul>
      </nav>
      <nav>
        <h3 class="text-xl font-bold mb-4">Legal</h3>
        <ul class="flex flex-col text-lg font-thin text-black/70 space-y-2">
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Privacy Policy</a> 
          <a class="cursor-pointer hover:text-black transition-colors" href="#">Terms of Service</a> 
        </ul>
      </nav>
    </div>
    <p class="text-[4rem] sm:text-[8rem] md:text-[15rem] leading-none tracking-tighter sm:tracking-normal overflow-hidden">FLORAVELLE</p>
  </div>
</footer>
