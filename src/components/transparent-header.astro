---
import "../styles/global.css"
---


<header class="t-header | absolute top-[-18%] w-full bg-transparent font-roboto flex items-center  z-50   border-white py-8 opacity-0">

  <div class="container mx-auto flex justify-between md:px-0 px-8">
<a href="/" class="md:text-3xl text-xl font-heading tracking-wide cursor-pointer text-white font-bold">Floravelle</a>
    <nav class="md:flex hidden gap-4 items-center list-none text-white text-xl font-semibold">
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="text-white md:text-xl text-md font-semibold">
      <a href="/collection">Collection</a>
    </div>

  </div>

</header>

<script>
import {gsap} from "gsap";

const animateHeader = () => {
  const header = document.querySelector(".t-header");

  gsap.to(header, {
    top : 0,
    opacity :1,
    duration :1.0,
    ease : "none"
  })
}

window.addEventListener('preloaderComplete', () => {
  animateHeader();
});

// Fallback in case preloader is missing or already completed
setTimeout(() => {
	const preloader = document.getElementById('preloader');
	if (!preloader && !window.hasOwnProperty('preloaderAnimated')) {
		animateHeader();
	}
}, 3000);

</script>
