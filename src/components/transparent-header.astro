---
import "../styles/global.css"
---


<header class="t-header | absolute top-[-18%] w-full bg-transparent font-roboto flex items-center z-50 py-4 md:py-8 opacity-0">

  <div class="container mx-auto flex justify-between md:px-0 px-6">
    <a href="/" class="md:text-3xl text-xl font-heading tracking-widest cursor-pointer text-white font-bold uppercase">Floravelle</a>
    <nav class="md:flex hidden gap-8 items-center list-none text-white text-lg font-semibold uppercase tracking-widest">
      <a href="/about" class="hover:text-white/70 transition-colors">About</a>
      <a href="/contact" class="hover:text-white/70 transition-colors">Contact</a>
    </nav>

    <div class="text-white md:text-lg text-base font-semibold uppercase tracking-wider">
      <a href="/collection" class="hover:text-white/70 transition-colors">Collection</a>
    </div>

  </div>

</header>

<script>
import {gsap} from "gsap";

const animateHeader = () => {
  const header = document.querySelector(".t-header");
  const isSkipped = (window as any).skipAnimations;

  gsap.to(header, {
    top : 0,
    opacity :1,
    duration : isSkipped ? 0 : 1.0,
    ease : "none"
  })
}

window.addEventListener('preloaderComplete', () => {
  animateHeader();
});

// Check if preloader already finished or should be skipped
if ((window as any).preloaderFinished || !(document.getElementById('preloader'))) {
  animateHeader();
} else {
  // Fallback in case preloader is missing or already completed
  setTimeout(() => {
    if (!(window as any).preloaderFinished) {
       animateHeader();
    }
  }, 3000);
}

</script>
