---

import "../styles/global.css"
import {Image} from "astro:assets"

import icon from "../assets/icon.png"

import manhaImg from "../assets/manha/manha-1.png"
import shadowImg from "../assets/shadow/shadow-2.png"
import odyessyImg from "../assets/odyssey/od-1.png"
import {products} from "../utils/data.ts"

---


<section class="reveal-section font-primary mt-16 md:mt-28">
  <div class="container mx-auto flex flex-col md:flex-row px-4 md:px-0 gap-4 md:gap-0">
    <div>
      <h1 class="text-4xl md:text-7xl mb-4 md:mb-8">Signature Scents</h1>
      <p class="text-lg md:text-2xl text-gray-600 md:px-2">Find the fragrance that feels uniquely yours and lingers beautifully wherever you go.</p>
    </div>
    <div class="w-full md:flex hidden items-start md:items-end justify-start md:justify-end">
      <Image
        src={icon}
        alt="arrow-left"
        class="cursor-pointer"
        id="prev"
      />
      <Image
        src={icon}
        alt="arrow-left"
        class="rotate-[180deg] cursor-pointer"
        id="next"
      />
      
    </div>
  </div>
  <div class="mt-8 md:mt-12 container mx-auto md:overflow-x-clip h-auto flex flex-col md:flex-row gap-8 md:gap-18 px-4 md:px-0">
    <div id="carousel" class="flex md:flex-row flex-col gap-8 md:gap-18 transition-transform duration-300">
      { products.map((product) => (
      <div class="w-full md:w-[28rem] h-auto md:h-[30rem] group flex-nowrap">
        <div class="w-full overflow-hidden h-[20rem] md:h-[25rem]">
          <Image
            src={product.src}
            alt={product.name}
            class="w-full h-full object-cover group-hover:scale-110 transition-all duration-120"
          />
        </div>
        <div class="flex justify-between mt-4">
          <div class='space-y-2 md:space-y-4'>
            <h3 class="text-xl md:text-2xl font-semibold capitalize">{product.name}</h3>
            <p class="text-gray-600 text-lg md:text-xl">{product.description}</p>
          </div>
          <div class="flex items-center">
            <a href={`/products/${product.name}`} class="text-base md:text-xl font-semibold border border-[#7A5633] text-[#8A5633] cursor-pointer hover:bg-[#7A5633] hover:text-white rounded-full p-2 cursor-pointer">View Details</a>
          </div>
        </div>
      </div> 
      ))}
    </div>
  </div>
</section>


<script>
import { gsap } from "gsap";
import { Draggable } from "gsap/Draggable";

gsap.registerPlugin(Draggable);

document.addEventListener("DOMContentLoaded", () => {
  let index = 0;

  const carousel = document.getElementById("carousel");
  const slides = document.querySelectorAll("#carousel > div");
  const total = slides.length;

  const next = document.getElementById("next");
  const prev = document.getElementById("prev");

  // Calculate slide width (including gap)
  const gap = 32; // gap-8 = 32px
  const slideWidth = slides[0].offsetWidth + gap;

  // Max index (adjust based on how many visible at once)
  const visibleSlides = window.innerWidth >= 768 ? 3 : 1;
  const maxIndex = total - visibleSlides;

  // Function to move carousel
  const goToSlide = (i) => {
    index = Math.max(0, Math.min(i, maxIndex));

    gsap.to(carousel, {
      x: -(index * slideWidth),
      duration: 0.2,
      ease: "none"
    });
  };

  // Buttons
  next.addEventListener("click", () => {
    goToSlide(index + 1);
  });

  prev.addEventListener("click", () => {
    goToSlide(index - 1);
  });

  // Draggable
  Draggable.create(carousel, {
    type: "x",
    inertia: true,
    edgeResistance: 0.85,
    bounds: {
      minX: -(slideWidth * maxIndex),
      maxX: 0
    },

    onDragEnd: function () {
      const draggedIndex = Math.round(Math.abs(this.x) / slideWidth);
      goToSlide(draggedIndex);
    }
  });

  // Optional: handle resize (keeps it responsive)
  window.addEventListener("resize", () => {
    const newVisible = window.innerWidth >= 768 ? 3 : 1;
    const newMaxIndex = total - newVisible;

    index = Math.min(index, newMaxIndex);

    gsap.set(carousel, {
      x: -(index * slideWidth)
    });
  });
});
</script>

