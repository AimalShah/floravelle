---

import "../styles/global.css"
import {Image} from "astro:assets"
import manhaImg from "../assets/manha.png"
import shadowImg from "../assets/shadow.png"
import odyessyImg from "../assets/odyssey.png"

const products = [
  {
    id: 1,
    name: "manha",
    src : manhaImg,
    description: "fresh floral elegance"
  },
  {
    id: 2,
    name: "shadow",
    src : shadowImg,
    description: "dark woody mystery"
  },
  {
    id: 3,
    name: "odyessy",
    src : odyessyImg,
    description: "bold citrus adventure"
  }
];
---


<section class="font-primary mt-16 md:mt-28">
  <div class="container mx-auto flex flex-col md:flex-row px-4 md:px-0 gap-4 md:gap-0">
    <div>
      <h1 class="text-4xl md:text-7xl mb-4 md:mb-8">Signature Scents</h1>
      <p class="text-lg md:text-2xl text-gray-600 md:px-2">Find the fragrance that feels uniquely yours and lingers beautifully wherever you go.</p>
    </div>
    <div class="w-full flex items-start md:items-end justify-start md:justify-end">
      <a href="#" class="font-bold text-lg md:text-xl underline cursor-pointer">View All</a>
    </div>
  </div>
  <div class="mt-8 md:mt-12 w-full container mx-auto flex flex-col md:flex-row gap-8 md:gap-18 px-4 md:px-0">
    { products.map((product) => (

    <div class="w-full md:w-[28rem] h-auto md:h-[30rem] cursor-pointer group">
      <div class="w-full overflow-hidden h-[20rem] md:h-[25rem] bg-red-400">
        <Image
          src={product.src}
          alt={product.name}
          class="w-full h-full object-cover group-hover:scale-110 transition-all duration-120"
        />
      </div>
      <div class="flex justify-between mt-4">
        <div class='space-y-2 md:space-y-4'>
          <h3 class="text-xl md:text-2xl font-semibold capitalize">{product.name}</h3>
          <p class="text-gray-600 text-lg md:text-xl">{product.description}</p>
        </div>
        <div class="flex items-center">
          <button class="text-base md:text-xl font-semibold border border-[#7A5633] text-[#8A5633] hover:bg-[#7A5633] hover:text-white rounded-full p-2 cursor-pointer">View Details</button>
        </div>
      </div>
    </div> 
    ))}
  </div>
</section>

