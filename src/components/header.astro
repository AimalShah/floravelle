---
import "../styles/global.css"
import Logo from "../assets/logo-1.png"
import {Image} from "astro:assets"
---

<header id="site-header" class="md:py-4 py-2 fixed top-0 left-0 w-full z-50 bg-[#F0EBE5] opacity-0 shadow-xl">
  <div class="flex container mx-auto items-center justify-between font-primary px-4 md:px-8">
    
    <!-- Logo -->
    <a href="/" class="text-2xl md:text-4xl cursor-pointer font-semibold z-[60] relative transition-colors duration-500 hover:text-[#8A5633]" id="header-logo">
      <Image
        src={Logo}
        alt="floravelle"
        class="rounded-fill md:size-16 size-18 object-contain "
      />
      <!-- Floravelle -->
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8 list-none font-semibold text-lg uppercase tracking-widest">
      <a href="/about" class="cursor-pointer hover:text-[#8A5633] transition-colors duration-300">About</a>
      <a href="/contact" class="cursor-pointer hover:text-[#8A5633] transition-colors duration-300">Contact</a>
    </nav>

    <div>
      <a href="/about" class="cursor-pointer hover:text-[#8A5633] transition-colors text-lg font-semibold duration-300">Collection</a>
    </div>

  </div>
</header>

<script>
import {gsap} from "gsap";
import {ScrollTrigger} from "gsap/ScrollTrigger"

gsap.registerPlugin(ScrollTrigger);


const headerScroll = () => {

const header = document.getElementById("site-header");
const hero = document.getElementById("hero");

if(!header || !hero) return;

  gsap.set(header, {y: -100,opacity : 0});
  
  ScrollTrigger.create({
    trigger: hero,
    start : "top+=30% top",
    onEnter : () => {
      console.log("Enter");
      gsap.to(header, {
        y:0,
        opacity :1,
        duration : 0.5,
        ease : "none"
      })
    },
    onLeaveBack : () => {
      console.log("leave");
      gsap.to(header,{
        y: -100,
        opacity : 0,
        duration : 0.1,
        ease : "none"
      })
    }
  });
}

  headerScroll();

  document.addEventListener("astro:page-load", () => {
    headerScroll()
  })

</script>

