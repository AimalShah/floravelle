---
import "../styles/global.css"
import heroBg from "../assets/hero-4.jpeg"
import heroMobileBg from "../assets/hero-4.jpeg"
import heroMobileBg2 from "../assets/hero-2.png"
import heroMobileBg3 from "../assets/hero-3.png"
import { Image } from "astro:assets"
import CarouselCounter from "../components/carousel-counter.astro"
---

<section id="hero" class="relative overflow-hidden bg-[#F0EBE5] md:h-[100dvh]">
  <Image 
    src={heroBg} 
    alt="Floravelle Hero Desktop" 
    class="absolute inset-0 w-full h-full object-cover md:object-[right_top] object-center z-0 hidden md:block"
    loading="eager"
    fetchpriority="high"
  />
  
  <!-- Mobile Single Image (16:9) -->
  <div class="block md:hidden w-full aspect-video relative z-0">
    <Image 
      src={heroMobileBg} 
      alt="Floravelle Hero Mobile" 
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/10"></div>
  </div>

  <div class="container h-full md:px-0 px-10 mx-auto text-white hidden md:flex flex-col justify-center md:gap-12 font-heading pt-32 z-10 relative pointer-events-none">
    <div class="flex flex-1 md:flex-row flex-col justify-between w-full pointer-events-auto">
      <div class="h-fit overflow-hidden flex items-center">
        <h1 class="md:text-[14rem] text-6xl translate-y-90 heading font-heading">Timeless</h1>
      </div>
      <div class="flex flex-col gap-2 justify-center text-xs md:text-lg font-roboto translate-y-60 opacity-0 paragraph">
        <p class="text-right md:text-left">Elegance isn't occasional — it is woven into the quiet rhythm<br class="md:block hidden"/> of everyday moments, shaping the way you move through the<br class="md:block hidden"/> world and defining a presence that lingers long after you leave.</p>
          <a href="/collection" class="text-right underline cursor-pointer">EXPLORE THE COLLECTION</a>
      </div>
    </div>
    <div class="flex flex-1 justify-end items-center ">
      <div class="overflow-hidden h-fit">
        <h1 class="md:text-[14rem] text-6xl text-right translate-y-96 heading leading-[0.8] py-4">Fragrance</h1>
      </div>
    </div>
  </div>
</section>

<script>
import {gsap} from "gsap";

const animate = () => {
  const hero = document.querySelector(".hero")
  const headings = document.querySelectorAll(".heading");
  const paragraph = document.querySelector(".paragraph");

  const isSkipped = (window as any).skipAnimations;

  headings.forEach((heading) => {
    gsap.to(heading, {
      y:0,
      duration : isSkipped ? 0 : 1.8,
      ease : "power3.out"
    });
  })


  gsap.to(paragraph,{
    y:0,
    opacity:1,
    duration : isSkipped ? 0 : 1.8,
    ease : "power3.out"
  });

};

// Wait for the custom preloader event before starting the animation
window.addEventListener('preloaderComplete', () => {
  animate();
});


// Check if preloader already finished or should be skipped
if ((window as any).preloaderFinished || !(document.getElementById('preloader'))) {
  animate();
} else {
  // Fallback in case preloader is missing or already completed
  setTimeout(() => {
    if (!(window as any).preloaderFinished) {
       animate();
    }
  }, 3000);
}
</script>


