---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

export const prerender = false;
---

<Layout 
  title="Checkout | FloraVelle" 
  description="Complete your purchase"
>
  <main class="min-h-screen bg-[#F0EBE5] py-16 md:py-32">
    <div class="container mx-auto px-4 md:px-8">
      <h1 class="text-4xl md:text-6xl font-heading text-[#3B2D20] uppercase tracking-widest mb-16 text-center">Checkout</h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Order Summary -->
        <div class="bg-white p-8 rounded-sm shadow-lg">
          <h2 class="text-2xl font-heading text-[#3B2D20] uppercase tracking-wider mb-8">Order Summary</h2>
          
          <div id="cart-items" class="space-y-6">
            <!-- Cart items rendered by JS -->
          </div>

          <div class="border-t border-[#A39579]/30 mt-8 pt-8 space-y-4">
            <div class="flex justify-between text-lg">
              <span class="text-[#A39579] uppercase tracking-wider">Subtotal</span>
              <span class="font-heading text-[#3B2D20]" id="subtotal">Rs. 0</span>
            </div>
            <div class="flex justify-between text-sm text-gray-500">
              <span>Shipping</span>
              <span>Calculated at next step</span>
            </div>
            <div class="flex justify-between text-xl font-heading pt-4 border-t border-[#A39579]/30">
              <span class="uppercase tracking-wider">Total</span>
              <span id="total">Rs. 0</span>
            </div>
          </div>
        </div>

        <!-- Checkout Form -->
        <div class="space-y-8">
          <!-- Customer Information Form -->
          <div class="bg-white p-8 rounded-sm shadow-lg">
            <h2 class="text-2xl font-heading text-[#3B2D20] uppercase tracking-wider mb-8">Customer Information</h2>
            
            <form id="checkout-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">First Name *</label>
                  <input type="text" name="firstName" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
                </div>
                <div>
                  <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">Last Name *</label>
                  <input type="text" name="lastName" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
                </div>
              </div>

              <div>
                <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">Email *</label>
                <input type="email" name="email" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
              </div>

              <div>
                <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">Phone *</label>
                <input type="tel" name="phone" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
              </div>

              <div>
                <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">Address *</label>
                <input type="text" name="address" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">City *</label>
                  <input type="text" name="city" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
                </div>
                <div>
                  <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">Postal Code *</label>
                  <input type="text" name="postalCode" required class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none" />
                </div>
              </div>

              <div>
                <label class="block text-sm uppercase tracking-wider text-[#A39579] mb-2">Order Notes (Optional)</label>
                <textarea name="customerNote" rows="3" class="w-full px-4 py-3 border border-[#A39579]/30 rounded-sm focus:border-[#7A5633] focus:outline-none"></textarea>
              </div>
            </form>
          </div>

          <!-- Payment Method -->
          <div class="bg-white p-8 rounded-sm shadow-lg">
            <h2 class="text-2xl font-heading text-[#3B2D20] uppercase tracking-wider mb-8">Payment Method</h2>
            
            <div id="payment-methods" class="space-y-4">
              <p class="text-gray-500">Loading payment methods...</p>
            </div>
          </div>

          <!-- Submit Button -->
          <button id="submit-order" class="w-full bg-[#3B2D20] text-white py-4 uppercase tracking-[0.3em] text-sm font-medium hover:bg-[#7A5633] transition-all duration-500 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed">
            Place Order
          </button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const API_BASE = '/api';

  let cartItemsList = [];
  let paymentMethodsList = [];

  try {
    const stored = localStorage.getItem('cart');
    if (stored) {
      cartItemsList = JSON.parse(stored);
    }
  } catch (e) {
    console.error('Failed to load cart:', e);
  }

  function updateTotals() {
    const subtotal = cartItemsList.reduce((acc: number, item: any) => acc + (item.price * item.quantity), 0);
    
    const subtotalEl = document.getElementById('subtotal');
    const totalEl = document.getElementById('total');
    if (subtotalEl) subtotalEl.textContent = `Rs. ${subtotal.toLocaleString()}`;
    if (totalEl) totalEl.textContent = `Rs. ${subtotal.toLocaleString()}`;
  }

  function renderCartItems() {
    const container = document.getElementById('cart-items');
    if (!container) return;
    
    if (cartItemsList.length === 0) {
      container.innerHTML = '<p class="text-center text-gray-500 py-8">Your cart is empty</p>';
      return;
    }
    
    container.innerHTML = cartItemsList.map((item: any) => `
      <div class="flex gap-4 border-b border-[#A39579]/20 pb-6">
        <div class="w-20 h-24 bg-[#E8E4DE] rounded-sm p-2 flex-shrink-0">
          <img src="${item.image}" alt="${item.name}" class="w-full h-full object-contain mix-blend-multiply" />
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-heading text-[#3B2D20] uppercase">${item.name}</h3>
          <p class="text-sm text-[#A39579]">${item.subtitle || ''}</p>
          <div class="flex justify-between items-center mt-2">
            <span class="text-sm">Qty: ${item.quantity}</span>
            <span class="font-medium">Rs. ${(item.price * item.quantity).toLocaleString()}</span>
          </div>
        </div>
      </div>
    `).join('');
  }

  async function fetchPaymentMethods() {
    try {
      const response = await fetch(`${API_BASE}/payment-methods`);
      const data = await response.json();
      paymentMethodsList = data.methods || [];
      renderPaymentMethods();
    } catch (error) {
      console.error('Failed to fetch payment methods:', error);
      const container = document.getElementById('payment-methods');
      if (container) {
        container.innerHTML = '<p class="text-red-500">Failed to load payment methods</p>';
      }
    }
  }

  function renderPaymentMethods() {
    const container = document.getElementById('payment-methods');
    if (!container) return;
    
    if (paymentMethodsList.length === 0) {
      container.innerHTML = '<p class="text-gray-500">No payment methods available</p>';
      return;
    }
    
    container.innerHTML = paymentMethodsList.map((method: any, index: number) => `
      <label class="flex items-center gap-4 p-4 border ${index === 0 ? 'border-[#7A5633]' : 'border-[#A39579]/30'} rounded-sm cursor-pointer hover:border-[#7A5633] transition-colors">
        <input type="radio" name="paymentMethod" value="${method.id}" ${index === 0 ? 'checked' : ''} class="w-5 h-5 text-[#7A5633]" />
        <div>
          <span class="block font-medium text-[#3B2D20]">${method.title}</span>
          <span class="text-sm text-gray-500">${method.description || ''}</span>
        </div>
      </label>
    `).join('');
  }

  async function submitOrder() {
    const form = document.getElementById('checkout-form') as HTMLFormElement;
    const formData = new FormData(form);
    
    const billing = {
      firstName: formData.get('firstName'),
      lastName: formData.get('lastName'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      address: formData.get('address'),
      city: formData.get('city'),
      postalCode: formData.get('postalCode'),
    };

    const paymentMethodEl = document.querySelector('input[name="paymentMethod"]:checked') as HTMLInputElement;
    const paymentMethod = paymentMethodEl?.value || 'cod';

    const orderData = {
      line_items: cartItemsList.map((item: any) => ({
        productId: item.id,
        quantity: item.quantity,
        price: item.price.toString(),
        name: item.name,
      })),
      billing,
      shipping: billing,
      paymentMethod,
      customerNote: formData.get('customerNote') || '',
    };

    try {
      const response = await fetch(`${API_BASE}/checkout`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(orderData),
      });

      const result = await response.json();

      if (result.success) {
        localStorage.removeItem('cart');
        // alert(`Order placed successfully! Order ID: ${result.orderId}`);
        window.location.href = '/thank-you?orderId=' + result.orderId;
      } else {
        alert('Failed to place order: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      console.error('Order submission error:', error);
      alert('Failed to place order. Please try again.');
    }
  }

  renderCartItems();
  updateTotals();
  fetchPaymentMethods();

  document.getElementById('submit-order')?.addEventListener('click', async (e) => {
    e.preventDefault();
    const form = document.getElementById('checkout-form') as HTMLFormElement;
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const submitBtn = document.getElementById('submit-order');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Processing...';
    }

    await submitOrder();
    
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Place Order';
    }
  });
</script>
