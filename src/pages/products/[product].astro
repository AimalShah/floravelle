---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { Image } from "astro:assets";
import AddToCartButton from "../../components/AddToCartButton";
import { woo, mapProduct } from "../../lib/api/woocommerce";

export async function getStaticPaths() {
  try {
    const products = await woo.getAllProducts(1, 100);
    return products.map((p) => ({
      params: { product: String(p.id) },
      props: { productData: mapProduct(p) },
    }));
  } catch (e) {
    console.error('Failed to fetch products for paths:', e);
    return [
      { params: { product: "1" }, props: { productData: null } },
    ];
  }
}

const { product } = Astro.params;
const { productData } = Astro.props || {};

const phoneNumber = "92333 1619295";
const message = productData?.name ? `Hi FLORAVELLE! I'm interested in ordering the perfume: ${productData.name}.` : '';
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

{(!productData) ? (
  <Layout title="Product Not Found | FloraVelle">
    <section class="min-h-screen bg-[#F0EBE5] flex items-center justify-center pt-40">
      <div class="container mx-auto px-6 text-center">
        <h1 class="text-4xl font-heading text-[#3B2D20] mb-8">Product Not Found</h1>
        <p class="text-gray-600 mb-8">Unable to load product details.</p>
        <a href="/collection" class="inline-block px-8 py-3 bg-[#3B2D20] text-white hover:bg-[#7A5633] transition-colors">
          Return to Collection
        </a>
      </div>
    </section>
  </Layout>
) : (
<Layout 
  title={`${productData.name} | FloraVelle`} 
  description={productData.description}
  image={productData.images && productData.images[0]}
>
  <section class="min-h-screen bg-[#F0EBE5] font-primary pt-40 pb-24 md:pt-48">
    <div class="container mx-auto px-6 md:px-12 max-w-[1400px]">
      
      <!-- Back Link -->
      <a href="/collection" class="inline-flex items-center text-[#00000] hover:text-[#8A5633] transition-colors mb-12 uppercase tracking-[0.2em] text-xs font-medium reveal-section">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Return to Collection
      </a>

      <div class="flex flex-col lg:flex-row gap-16 lg:gap-32">
        
        {/* Image Showcase (Left Side) */}
        <div class="w-full lg:w-[55%] flex flex-col gap-6 reveal-section">
          {/* Main Display */}
          <div class="w-full bg-[#E8E4DE] aspect-[4/5] flex items-center justify-center relative shadow-sm overflow-hidden p-8 md:p-20">
            <div class="w-full h-full overflow-hidden">
              <img 
                id="main-product-image"
                src={productData.images?.[0]} 
                alt={`FLORAVELLE ${productData.name}`} 
                class="w-full h-full object-cover mix-blend-multiply drop-shadow-2xl transition-all duration-700 ease-in-out"
              />
            </div>
          </div>
          
          {/* Thumbnails */}
          {productData.images && productData.images.length > 1 && (
            <div class="flex gap-4 overflow-x-auto py-4 scrollbar-hide">
              {productData.images.map((img, index) => (
                <button 
                  class={`thumbnail-btn flex-shrink-0 w-20 md:w-28 aspect-square bg-[#E8E4DE] ${index === 0 ? 'opacity-100' : 'opacity-60'} hover:opacity-100 transition-opacity duration-300 p-4 focus:outline-none`}
                  data-image-src={img}
                >
                  <img src={img} alt={`${productData.name} view ${index + 1}`} class="w-full h-full object-contain mix-blend-multiply" />
                </button>
              ))}
            </div>
          )}
        </div>

        {/* Product Information (Right Side) */}
        <div class="w-full lg:w-[45%] flex flex-col justify-center reveal-section pt-8 lg:pt-0">
          
          <div class="mb-12">
            <p class="text-[#A39579] text-sm md:text-base uppercase tracking-[0.3em] font-medium mb-4">{productData.notes?.top || 'Signature Collection'}</p>
            <h1 class="text-5xl md:text-8xl font-heading text-[#3B2D20] capitalize leading-none mb-8">{productData.name}</h1>
            <div class="flex items-center gap-4">
              {productData.salePrice ? (
                <>
                  <p class="text-2xl md:text-4xl text-gray-800 font-light line-through opacity-50">Rs. {parseInt(productData.regularPrice) || 2500}</p>
                  <p class="text-2xl md:text-4xl text-[#7A5633] font-light">Rs. {parseInt(productData.salePrice) || 2500}</p>
                </>
              ) : (
                <p class="text-2xl md:text-4xl text-gray-800 font-light">Rs. {parseInt(productData.regularPrice) || 2500}</p>
              )}
            </div>
          </div>
          
          <div class="w-16 h-[1px] bg-[#A39579] mb-12"></div>
          
          <p class="text-base md:text-xl text-gray-700 leading-relaxed mb-16 max-w-lg">
            {productData.description || 'A crafted essence for the modern identity.'}
          </p>

          {/* Fragrance Notes */}
          <div class="mb-20">
            <h3 class="text-sm font-medium uppercase tracking-[0.2em] text-[#A39579] mb-8">Olfactory Profile</h3>
            <div class="space-y-6 text-base text-gray-800 max-w-sm">
              <div class="flex justify-between border-b border-[#A39579]/20 pb-4">
                <span class="font-medium text-[#3B2D20]">Top</span>
                <span class="text-right text-gray-600">{productData.notes?.top || 'N/A'}</span>
              </div>
              <div class="flex justify-between border-b border-[#A39579]/20 pb-4">
                <span class="font-medium text-[#3B2D20]">Heart</span>
                <span class="text-right text-gray-600">{productData.notes?.heart || 'N/A'}</span>
              </div>
              <div class="flex justify-between border-b border-[#A39579]/20 pb-4">
                <span class="font-medium text-[#3B2D20]">Base</span>
                <span class="text-right text-gray-600">{productData.notes?.base || 'N/A'}</span>
              </div>
            </div>
          </div>

          {/* Actions */}
          <div class="mt-auto space-y-4">
             <p class="text-[#A39579] tracking-[0.2em] font-medium uppercase text-xs mb-4">Purchase Options</p>
             <div class="flex flex-col  gap-4">
                <AddToCartButton 
                  client:load 
                  product={{
                    id: String(product),
                    name: productData.name,
                    price: parseInt(productData.salePrice || productData.regularPrice) || 2500,
                    image: productData.images?.[0],
                    subtitle: productData.notes?.top || 'Signature Collection'
                  }}
                  className="w-full !py-5 !text-xl"
                />
                <a 
                  href={whatsappUrl} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="w-full inline-flex items-center justify-center gap-4 border border-[#7A5633] text-[#8A5633] hover:bg-[#7A5633] hover:text-white py-5 px-8 text-base md:text-xl font-medium transition-colors duration-500 uppercase tracking-widest"
                >
                  Reserve via WhatsApp
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </a>
             </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>
)}
---

<script>
  // Setup interactivity for the image gallery
  const setupGallery = () => {
    const mainImage = document.getElementById('main-product-image');
    const thumbnails = document.querySelectorAll('.thumbnail-btn');

    if (mainImage && thumbnails.length > 0) {
      thumbnails.forEach(thumb => {
        thumb.addEventListener('click', () => {
          // Update main image source
          const newSrc = thumb.getAttribute('data-image-src');
          if (newSrc && mainImage.src !== newSrc) {
            // Simple scale/fade effect
            mainImage.style.opacity = '0';
            mainImage.style.transform = 'scale(0.95)';
            
            setTimeout(() => {
              mainImage.setAttribute('src', newSrc);
              mainImage.style.opacity = '1';
              mainImage.style.transform = 'scale(1)';
            }, 300);
            
            // Update active state on buttons utilizing opacity instead of borders
            thumbnails.forEach(t => {
              t.classList.remove('opacity-100');
              t.classList.add('opacity-60');
            });
            thumb.classList.remove('opacity-60');
            thumb.classList.add('opacity-100');
          }
        });
      });
    }
  };

  // Run on first load
  setupGallery();
  
  // Also run when navigating with Astro View Transitions (if enabled)
  document.addEventListener('astro:page-load', setupGallery);
</script>
