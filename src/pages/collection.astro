---
import Layout from "../layouts/Layout.astro"
import "../styles/global.css"
import { Image } from "astro:assets"

import manhaImg from "../assets/manha.png"
import shadowImg from "../assets/shadow.png"
import odyessyImg from "../assets/odyssey.png"
import mirageImg from "../assets/mirage.png"

const collection = [
  {
    name: "Mirage",
    src: mirageImg,
    subtitle: "Ethereal Desert Breeze",
    price: "Rs. 2500",
    slug: "mirage",
    bgClass: "bg-[#E8E4DE]"
  },
  {
    name: "Manha",
    src: manhaImg,
    subtitle: "Fresh Floral Elegance",
    price: "Rs. 2500",
    slug: "manha",
    bgClass: "bg-[#E8E4DE]"
  },
  {
    name: "Shadow",
    src: shadowImg,
    subtitle: "Dark Woody Mystery",
    price: "Rs. 2500",
    slug: "shadow",
    bgClass: "bg-[#E8E4DE]"
  },
  {
    name: "Odyessy",
    src: odyessyImg,
    subtitle: "Bold Citrus Adventure",
    price: "Rs. 2500",
    slug: "odyessy",
    bgClass: "bg-[#E8E4DE]"
  }
];
---

<Layout>
  <section class="mt-20 md:mt-28 mb-20 space-y-12 md:space-y-24 min-h-screen">
    <!-- Header -->
    <div class="container mx-auto px-4 md:px-0 text-center">
      <h1 class="font-primary text-4xl md:text-6xl text-center mb-4">The <span class="italic text-[#8A5633]">Collection</span></h1>
      <p class="text-lg md:text-xl font-primary font-thin text-[#A39579] tracking-widest uppercase mb-4">Discover Your Signature Scent</p>
      <div class="bg-[linear-gradient(90deg,rgba(255,255,255,0)_0%,rgba(196,176,124,1)_40%,rgba(208,192,150,1)_72%,rgba(255,255,255,0)_100%)] h-[2px] w-full max-w-xl mx-auto my-4 mt-8"></div>
    </div>

    <!-- Products Grid -->
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-16">
        {collection.map((product) => (
          <a href={`/products/${product.slug}`} class="group w-full flex flex-col font-primary items-center text-center">
            
            <div class={`w-full ${product.bgClass} p-8 h-[450px] md:h-[550px] flex items-center justify-center relative shadow-sm mb-8 overflow-hidden`}>
              <div class="absolute inset-0 bg-white/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
              <Image 
                src={product.src} 
                alt={`FLORAVELLE ${product.name}`} 
                class="w-[80%] md:w-[70%] h-auto max-h-full object-contain drop-shadow-2xl group-hover:scale-105 transition-transform duration-700 ease-out"
              />
            </div>
            
            <h2 class="text-3xl font-bold mb-2 capitalize text-gray-900 group-hover:text-[#8A5633] transition-colors duration-300">{product.name}</h2>
            <p class="text-[#A39579] text-sm uppercase tracking-[0.2em] font-light mb-4">{product.subtitle}</p>
            <p class="text-xl font-semibold text-gray-800 mb-6">{product.price}</p>
            
            <span class="inline-flex items-center justify-center border border-[#1A1A1A] group-hover:bg-[#1A1A1A] text-[#1A1A1A] group-hover:text-white py-3 px-8 text-sm font-medium transition-colors duration-300 uppercase tracking-widest">
              View Details
            </span>
            
          </a>
        ))}
      </div>
    </div>
    
  </section>
</Layout>
