---
import Layout from "../layouts/Layout.astro"
import "../styles/global.css"
---

<Layout>
  <section class="mt-12 md:mt-20 mb-20 space-y-8 md:space-y-18">
    <div class="container mx-auto px-4 md:px-0 text-center">
      <h1 class="font-primary text-4xl md:text-6xl text-center mb-4">Contact <span class="italic text-[#8A5633]">Us</span></h1>
      <p class="text-lg md:text-xl font-primary font-thin text-[#A39579] tracking-widest uppercase">We'd Love to Hear From You</p>
    </div>

    <div class="md:container mx-auto mt-12 md:mt-18 px-0 md:px-0">
      <div class="bg-[#E8E4DE] p-4  md:p-14 lg:p-20 shadow-sm flex flex-col md:flex-row gap-12 md:gap-20">
        
        {/* Contact Information */}
        <div class="flex-1 font-primary flex flex-col justify-center space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl text-gray-800 mb-2">Get in Touch</h2>
            <p class="text-lg md:text-xl text-gray-700 leading-relaxed">
              Whether you have a question about our collections, need assistance finding your signature scent, or simply want to share your thoughts, we are here for you.
            </p>
          </div>
          
          <div class="space-y-4 text-lg md:text-xl text-gray-700">
            <div>
              <p class="font-semibold text-gray-800">Email</p>
              <p class="italic text-[#8A5633]">hello@floravelle.com</p>
            </div>
            <div>
              <p class="font-semibold text-gray-800">Phone</p>
              <p>+92 (0) 123 456 7890</p>
            </div>
            <div>
              <p class="font-semibold text-gray-800">Location</p>
              <p>Lahore, Pakistan</p>
            </div>
          </div>
          
          <div class="bg-[linear-gradient(90deg,rgba(255,255,255,0)_0%,rgba(196,176,124,1)_40%,rgba(208,192,150,1)_72%,rgba(255,255,255,0)_100%)] h-[2px] w-full my-4"></div>
          
          <p class="italic text-[#A39579] text-xl">
            "Your scent, your signature."
          </p>
        </div>

        {/* Contact Form */}
        <div class="flex-1 bg-white p-8 md:p-12 shadow-sm">
          <form class="font-primary flex flex-col space-y-6">
            <div class="flex flex-col">
              <label for="name" class="text-gray-700 mb-2">Full Name</label>
              <input type="text" id="name" name="name" class="border-b-2 border-gray-300 focus:border-[#8A5633] outline-none py-2 bg-transparent transition-colors" required />
            </div>
            
            <div class="flex flex-col">
              <label for="email" class="text-gray-700 mb-2">Email Address</label>
              <input type="email" id="email" name="email" class="border-b-2 border-gray-300 focus:border-[#8A5633] outline-none py-2 bg-transparent transition-colors" required />
            </div>
            
            <div class="flex flex-col">
              <label for="subject" class="text-gray-700 mb-2">Subject</label>
              <input type="text" id="subject" name="subject" class="border-b-2 border-gray-300 focus:border-[#8A5633] outline-none py-2 bg-transparent transition-colors" required />
            </div>
            
            <div class="flex flex-col">
              <label for="message" class="text-gray-700 mb-2">Message</label>
              <textarea id="message" name="message" rows="4" class="border-b-2 border-gray-300 focus:border-[#8A5633] outline-none py-2 bg-transparent transition-colors resize-none" required></textarea>
            </div>
            
            <button type="submit" class="text-lg md:text-xl font-semibold border-[#7A5633] border-2 text-[#8A5633] hover:bg-[#7A5633] hover:text-white rounded-full px-6 py-3 mt-4 transition-colors cursor-pointer self-start md:self-stretch text-center">
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</Layout>
